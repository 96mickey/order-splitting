{
  "info": {
    "_postman_id": "a1b2c3d4-auth-starter",
    "name": "Auth Starter",
    "description": "Import this collection. All requests live under the **Auth Starter** folder. Variables: `base_url`, `token` (set automatically after Register/Login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3010"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth Starter",
      "description": "Every endpoint from `curl-examples.md`, grouped here. Open a request → **Docs** to see the matching cURL.",
      "item": [
        {
          "name": "Health",
          "description": "```bash\ncurl -s http://localhost:3010/healthz\n```\n\nWith collection variable:\n```bash\ncurl -s {{base_url}}/healthz\n```",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/healthz"
          }
        },
        {
          "name": "Register",
          "description": "```bash\ncurl -s -X POST http://localhost:3010/api/v1/auth/register \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"email\": \"you@example.com\",\n    \"password\": \"password12\",\n    \"first_name\": \"Mayank\",\n    \"last_name\": \"Nauriyal\"\n  }'\n```",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  var j = pm.response.json();",
                  "  if (j.token) { pm.collectionVariables.set('token', j.token); }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"password12\",\n  \"first_name\": \"Mayank\",\n  \"last_name\": \"Nauriyal\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "description": "```bash\ncurl -s -X POST http://localhost:3010/api/v1/auth/login \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"email\": \"you@example.com\",\n    \"password\": \"password12\"\n  }'\n```",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  var j = pm.response.json();",
                  "  if (j.token) { pm.collectionVariables.set('token', j.token); }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"password12\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        },
        {
          "name": "Me (Bearer)",
          "description": "```bash\ncurl -s http://localhost:3010/api/v1/auth/me \\\n  -H \"Authorization: Bearer YOUR_TOKEN\"\n```\n\nIn Postman, `YOUR_TOKEN` is `{{token}}` (set by Register/Login tests).",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/auth/me"
          }
        },
        {
          "name": "Me (JWT header)",
          "description": "```bash\ncurl -s http://localhost:3010/api/v1/auth/me \\\n  -H \"Authorization: JWT YOUR_TOKEN\"\n```",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "JWT {{token}}"
              }
            ],
            "url": "{{base_url}}/api/v1/auth/me"
          }
        },
        {
          "name": "Example — protected ping",
          "description": "```bash\ncurl -s http://localhost:3010/api/v1/example/protected/ping \\\n  -H \"Authorization: Bearer YOUR_TOKEN\"\n```",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/example/protected/ping"
          }
        }
      ]
    }
  ]
}
