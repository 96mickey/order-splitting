NODE_ENV=development
PORT=3010
TRUST_PROXY=false

# CORS
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SCOPE=global
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Redis (optional — disable for local if not running Redis)
REDIS_ENABLED=false
# REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=order-splitter:

# Logging (Winston)
SERVICE_NAME=order-splitter
# Access logs: 2xx/3xx use `info`, 4xx `warn`, 5xx `error` (see api/middlewares/http-log.ts).
# Keep `info` or lower so successful request latency lines appear on the console transport.
LOG_LEVEL=info
LOG_DIR=./logs
LOG_PRETTY_CONSOLE=true
LOG_HTTP_BODY=true
LOG_HTTP_HEADERS=true
# When true, bracket access line also attaches structured http_request meta (Winston).
LOG_HTTP_ACCESS_JSON=false
# false in production (default): console + error file only — skips combined/http rotating files (lower latency).
LOG_ROTATING_FILES=true
