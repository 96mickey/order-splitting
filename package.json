{
  "name": "auth-starter",
  "version": "1.0.0",
  "description": "Minimal Express + Sequelize + JWT starter for auth and interview scaffolding",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "migrate": "sequelize-cli db:migrate --require ts-node/register/transpile-only",
    "migrate:undo": "sequelize-cli db:migrate:undo --require ts-node/register/transpile-only",
    "seed": "sequelize-cli db:seed:all --require ts-node/register/transpile-only",
    "seed:undo": "sequelize-cli db:seed:undo:all --require ts-node/register/transpile-only",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "celebrate": "^15.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv-safe": "^8.2.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^4.6.0",
    "http-status": "^1.7.4",
    "ioredis": "^5.10.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/method-override": "^0.0.35",
    "@types/node": "^22.10.2",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "eslint": "^7.32.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-plugin-import": "^2.29.1",
    "sequelize-cli": "^6.6.2",
    "sqlite3": "^6.0.1",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "tar": "^7.5.12",
    "vite": "^7.1.12"
  }
}
