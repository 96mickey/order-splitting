{
  "name": "order-splitter",
  "version": "1.0.0",
  "description": "TypeScript Express skeleton for Order Splitter POC (in-memory API — auth/DB stripped for now)",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "body-parser": "^1.20.3",
    "celebrate": "^15.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv-safe": "^8.2.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^4.6.0",
    "http-status": "^1.7.4",
    "ioredis": "^5.10.1",
    "joi": "^17.13.1",
    "method-override": "^3.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/method-override": "^0.0.35",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "eslint": "^7.32.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-plugin-import": "^2.29.1",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "tar": "^7.5.12",
    "vite": "^7.1.12"
  }
}
